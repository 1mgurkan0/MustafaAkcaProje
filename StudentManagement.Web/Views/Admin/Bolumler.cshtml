@model IEnumerable<StudentManagement.Services.ViewModels.Admin.BolumViewModel>
@{
    ViewData["Title"]      = "Bölümler";
    ViewData["Breadcrumb"] = "Bölümler";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Bölümler</h1>
        <p class="page-subtitle">Tüm akademik bölümleri yönetin.</p>
    </div>
    <div class="page-actions">
        <a href="/Admin/BolumOlustur" class="btn btn-primary">
            <i class="fas fa-plus"></i> Yeni Bölüm
        </a>
    </div>
</div>

<div class="card table-card">
    <div class="table-toolbar">
        <div class="table-search">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="Bölüm ara..." data-table="bolumTable" />
        </div>
        <div style="font-size:.78rem; color:var(--color-gray-400);">
            Toplam <strong>@Model.Count()</strong> bölüm
        </div>
    </div>

    <div class="table-responsive">
        <table class="ubys-table" id="bolumTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Bölüm Kodu</th>
                    <th>Bölüm Adı</th>
                    <th>Min. Mezuniyet AKTS</th>
                    <th>Öğrenci</th>
                    <th>Ders</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td class="text-muted text-sm">@b.Id</td>
                        <td>
                            <span class="badge badge-role">@b.BolumKodu</span>
                        </td>
                        <td>
                            <div class="primary">@b.BolumAdi</div>
                        </td>
                        <td>@b.MinMezuniyetAkts AKTS</td>
                        <td>
                            <span style="font-weight:700;">@b.OgrenciSayisi</span>
                        </td>
                        <td>
                            <span style="font-weight:700;">@b.DersSayisi</span>
                        </td>
                        <td>
                            @if (b.IsActive)
                            {
                                <span class="badge badge-success"><i class="fas fa-circle" style="font-size:.5rem;"></i> Aktif</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">Pasif</span>
                            }
                        </td>
                        <td>
                            <div class="table-actions">
                                <a href="/Admin/BolumDuzenle/@b.Id"
                                   class="btn btn-outline-secondary btn-icon btn-sm"
                                   title="Düzenle">
                                    <i class="fas fa-pen"></i>
                                </a>
                                <form asp-action="BolumSil" asp-controller="Admin"
                                      asp-route-id="@b.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-outline-danger btn-icon btn-sm"
                                            data-confirm="@b.BolumAdi bölümünü silmek istediğinize emin misiniz?"
                                            data-confirm-title="Bölüm Sil"
                                            data-confirm-type="danger"
                                            data-confirm-btn="Evet, Sil"
                                            title="Sil">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon"><i class="fas fa-building-columns"></i></div>
            <div class="empty-state-title">Henüz bölüm eklenmemiş</div>
            <div class="empty-state-text">İlk bölümü eklemek için "Yeni Bölüm" butonunu kullanın.</div>
        </div>
    }
</div>
