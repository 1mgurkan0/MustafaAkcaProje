@model StudentManagement.Services.ViewModels.Admin.DersOlusturViewModel
@{
    ViewData["Title"]      = "Yeni Ders";
    ViewData["Breadcrumb"] = "Ders Ekle";
}
<div class="page-header">
    <div><h1 class="page-title">Yeni Ders Ekle</h1></div>
    <a href="/Admin/DersKatalogu" class="btn btn-outline-secondary"><i class="fas fa-arrow-left"></i> Geri</a>
</div>
<div style="max-width:580px;">
    <div class="card">
        <div class="card-header"><div class="card-title"><i class="fas fa-book-medical"></i> Ders Bilgileri</div></div>
        <div class="card-body">
            <form asp-action="DersOlustur" asp-controller="Admin" method="post" novalidate>
                @Html.AntiForgeryToken()
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="DersKodu" class="form-label">Ders Kodu <span class="required">*</span></label>
                        <input asp-for="DersKodu" class="form-control" placeholder="BIL101" maxlength="15"
                               style="text-transform:uppercase;" />
                        <span asp-validation-for="DersKodu" class="invalid-feedback"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="BolumId" class="form-label">Bölüm <span class="required">*</span></label>
                        <select asp-for="BolumId" class="form-control" asp-items="ViewBag.Bolumler">
                            <option value="">— Seçiniz —</option>
                        </select>
                        <span asp-validation-for="BolumId" class="invalid-feedback"></span>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="DersAdi" class="form-label">Ders Adı <span class="required">*</span></label>
                    <input asp-for="DersAdi" class="form-control" placeholder="örn: Veri Yapıları" maxlength="150" />
                    <span asp-validation-for="DersAdi" class="invalid-feedback"></span>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Akts" class="form-label">AKTS <span class="required">*</span></label>
                        <input asp-for="Akts" class="form-control" type="number" min="1" max="8" />
                        <span asp-validation-for="Akts" class="invalid-feedback"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="MaxKontenjan" class="form-label">Kontenjan <span class="required">*</span></label>
                        <input asp-for="MaxKontenjan" class="form-control" type="number" min="1" max="500" />
                        <span asp-validation-for="MaxKontenjan" class="invalid-feedback"></span>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="Aciklama" class="form-label">Açıklama</label>
                    <textarea asp-for="Aciklama" class="form-control" rows="2" maxlength="500"></textarea>
                </div>
                <div style="display:flex; gap:10px; justify-content:flex-end;">
                    <a href="/Admin/DersKatalogu" class="btn btn-outline-secondary">İptal</a>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
