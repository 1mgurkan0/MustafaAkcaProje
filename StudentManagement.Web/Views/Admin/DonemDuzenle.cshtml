@model StudentManagement.Services.ViewModels.Admin.DonemDuzenleViewModel
@using StudentManagement.Core.Enums
@{
    ViewData["Title"]      = "Dönem Düzenle";
    ViewData["Breadcrumb"] = "Dönem Düzenle";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Dönem Düzenle</h1>
        <p class="page-subtitle"><strong>@Model.DonemKodu</strong></p>
    </div>
    <a href="/Admin/Donemler" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left"></i> Geri
    </a>
</div>

<div style="max-width:560px;">
    <div class="card">
        <div class="card-header">
            <div class="card-title"><i class="fas fa-pen"></i> Dönem Bilgilerini Güncelle</div>
        </div>
        <div class="card-body">
            <form asp-action="DonemDuzenle" asp-controller="Admin" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />

                <div class="form-group">
                    <label class="form-label">Dönem Kodu</label>
                    <input class="form-control" value="@Model.DonemKodu" disabled />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Yil" class="form-label">Yıl <span class="required">*</span></label>
                        <input asp-for="Yil" class="form-control" type="number" min="2000" max="2100" />
                        <span asp-validation-for="Yil" class="invalid-feedback"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="DonemTur" class="form-label">Dönem Türü <span class="required">*</span></label>
                        <select asp-for="DonemTur" class="form-control"
                                asp-items="Html.GetEnumSelectList<DonemTur>()">
                        </select>
                        <span asp-validation-for="DonemTur" class="invalid-feedback"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="DersKayitBaslangic" class="form-label">Kayıt Başlangıç</label>
                        <input asp-for="DersKayitBaslangic" class="form-control" type="date" />
                        <span asp-validation-for="DersKayitBaslangic" class="invalid-feedback"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="DersKayitBitis" class="form-label">Kayıt Bitiş</label>
                        <input asp-for="DersKayitBitis" class="form-control" type="date" />
                        <span asp-validation-for="DersKayitBitis" class="invalid-feedback"></span>
                    </div>
                </div>

                @if (Model.AktifMi)
                {
                    <div class="alert alert-info">
                        <i class="fas fa-circle-info"></i>
                        <div class="alert-body alert-text">Bu dönem şu anda <strong>aktif dönem</strong>dir.</div>
                    </div>
                }

                <div style="display:flex; gap:10px; justify-content:flex-end;">
                    <a href="/Admin/Donemler" class="btn btn-outline-secondary">İptal</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Güncelle
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
