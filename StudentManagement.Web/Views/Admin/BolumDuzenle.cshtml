@model StudentManagement.Services.ViewModels.Admin.BolumDuzenleViewModel
@{
    ViewData["Title"]      = "Bölüm Düzenle";
    ViewData["Breadcrumb"] = "Bölüm Düzenle";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Bölüm Düzenle</h1>
        <p class="page-subtitle"><strong>@Model.BolumKodu</strong> — @Model.BolumAdi</p>
    </div>
    <a href="/Admin/Bolumler" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left"></i> Geri
    </a>
</div>

<div style="max-width:560px;">
    <div class="card">
        <div class="card-header">
            <div class="card-title"><i class="fas fa-pen"></i> Bölüm Bilgilerini Güncelle</div>
        </div>
        <div class="card-body">
            <form asp-action="BolumDuzenle" asp-controller="Admin" method="post" id="bolumForm" novalidate>
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />

                <div class="form-group">
                    <label class="form-label">Bölüm Kodu</label>
                    <input class="form-control" value="@Model.BolumKodu" disabled />
                    <div class="form-text">Bölüm kodu değiştirilemez.</div>
                </div>

                <div class="form-group">
                    <label asp-for="BolumAdi" class="form-label">Bölüm Adı <span class="required">*</span></label>
                    <input asp-for="BolumAdi" class="form-control" maxlength="100" />
                    <span asp-validation-for="BolumAdi" class="invalid-feedback"></span>
                </div>

                <div class="form-group">
                    <label asp-for="MinMezuniyetAkts" class="form-label">Minimum Mezuniyet AKTS <span class="required">*</span></label>
                    <div class="input-group">
                        <input asp-for="MinMezuniyetAkts" class="form-control" type="number" min="60" max="300" />
                        <span class="input-group-text">AKTS</span>
                    </div>
                    <span asp-validation-for="MinMezuniyetAkts" class="invalid-feedback"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Aciklama" class="form-label">Açıklama</label>
                    <textarea asp-for="Aciklama" class="form-control" rows="3" maxlength="500"></textarea>
                </div>

                <div class="form-group">
                    <label class="form-check">
                        <input asp-for="IsActive" type="checkbox" />
                        <span>Aktif</span>
                    </label>
                </div>

                <div style="display:flex; gap:10px; justify-content:flex-end; margin-top:8px;">
                    <a href="/Admin/Bolumler" class="btn btn-outline-secondary">İptal</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Güncelle
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
