@model StudentManagement.Services.ViewModels.Admin.AdminDashboardViewModel
@{
    ViewData["Title"]      = "Dashboard";
    ViewData["Breadcrumb"] = "Yönetim Paneli";
}

<!-- Stat Grid -->
<div class="stat-grid">
    <div class="stat-card blue">
        <div class="stat-icon"><i class="fas fa-users"></i></div>
        <div class="stat-body">
            <div class="stat-value">@Model.ToplamOgrenci</div>
            <div class="stat-label">Toplam Öğrenci</div>
            <div class="stat-change neutral"><i class="fas fa-building-columns"></i> @Model.ToplamBolum bölüm</div>
        </div>
    </div>
    <div class="stat-card green">
        <div class="stat-icon"><i class="fas fa-chalkboard-user"></i></div>
        <div class="stat-body">
            <div class="stat-value">@Model.ToplamOgretmen</div>
            <div class="stat-label">Öğretmen</div>
            <div class="stat-change neutral"><i class="fas fa-book"></i> @Model.ToplamDersAtama aktif atama</div>
        </div>
    </div>
    <div class="stat-card purple">
        <div class="stat-icon"><i class="fas fa-book"></i></div>
        <div class="stat-body">
            <div class="stat-value">@Model.ToplamDers</div>
            <div class="stat-label">Ders Kataloğu</div>
            <div class="stat-change neutral"><i class="fas fa-calendar"></i> @Model.AktifDonemAdi</div>
        </div>
    </div>
    <div class="stat-card yellow">
        <div class="stat-icon"><i class="fas fa-inbox"></i></div>
        <div class="stat-body">
            <div class="stat-value">@Model.BekleyenTalepSayisi</div>
            <div class="stat-label">Bekleyen Talep</div>
            <div class="stat-change @(Model.BekleyenTalepSayisi > 0 ? "up" : "neutral")">
                @(Model.BekleyenTalepSayisi > 0 ? "Onay bekliyor" : "Temiz")
            </div>
        </div>
    </div>
</div>

<!-- İçerik Satırı -->
<div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">

    <!-- Son Kayıt Talepleri -->
    <div class="card">
        <div class="card-header">
            <div class="card-title"><i class="fas fa-inbox"></i> Son Ders Kayıt Talepleri</div>
            <a href="/OgrenciIsleri/Talepler" class="btn btn-ghost btn-sm">Tümü <i class="fas fa-arrow-right"></i></a>
        </div>
        <div class="card-body" style="padding:0;">
            @if (Model.SonTalepler?.Any() == true)
            {
                <table class="ubys-table">
                    <thead>
                        <tr>
                            <th>Öğrenci</th>
                            <th>Ders</th>
                            <th>Tarih</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.SonTalepler)
                        {
                            <tr>
                                <td>
                                    <div class="primary">@t.OgrenciAdi</div>
                                    <div class="secondary">@t.OgrenciNo</div>
                                </td>
                                <td>
                                    <div class="primary">@t.DersAdi</div>
                                    <div class="secondary">@t.DersKodu</div>
                                </td>
                                <td><span data-date="@t.TalepTarihi"></span></td>
                                <td><span class="badge badge-talep">Bekliyor</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state" style="padding:28px;">
                    <div class="empty-state-icon"><i class="fas fa-inbox"></i></div>
                    <div class="empty-state-title">Bekleyen talep yok</div>
                </div>
            }
        </div>
    </div>

    <!-- Bölüm Doluluk Oranları -->
    <div class="card">
        <div class="card-header">
            <div class="card-title"><i class="fas fa-chart-bar"></i> Bölüm Öğrenci Dağılımı</div>
            <a href="/Admin/Bolumler" class="btn btn-ghost btn-sm">Bölümler <i class="fas fa-arrow-right"></i></a>
        </div>
        <div class="card-body">
            @if (Model.BolumIstatistikleri?.Any() == true)
            {
                @foreach (var b in Model.BolumIstatistikleri)
                {
                    var oran = Model.ToplamOgrenci > 0
                        ? (int)Math.Round((double)b.OgrenciSayisi / Model.ToplamOgrenci * 100)
                        : 0;
                    <div style="margin-bottom:16px;">
                        <div class="d-flex items-center justify-between mb-1">
                            <span style="font-size:.82rem; font-weight:700; color:var(--color-gray-800);">@b.BolumAdi</span>
                            <span style="font-size:.75rem; font-weight:700; color:var(--color-gray-500);">@b.OgrenciSayisi öğrenci</span>
                        </div>
                        <div class="progress">
                            <div class="progress-bar" style="width:@oran%"></div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

</div>

<!-- Alt Satır -->
<div style="display:grid; grid-template-columns:2fr 1fr; gap:20px; margin-top:20px;">

    <!-- Son Öğrenciler -->
    <div class="card">
        <div class="card-header">
            <div class="card-title"><i class="fas fa-users"></i> Son Kayıt Olan Öğrenciler</div>
            <a href="/Admin/Ogrenciler" class="btn btn-ghost btn-sm">Tümü <i class="fas fa-arrow-right"></i></a>
        </div>
        <div class="card-body" style="padding:0;">
            @if (Model.SonOgrenciler?.Any() == true)
            {
                <table class="ubys-table">
                    <thead>
                        <tr><th>Öğrenci</th><th>No</th><th>Bölüm</th><th>Durum</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model.SonOgrenciler)
                        {
                            <tr>
                                <td><div class="primary">@o.TamAd</div><div class="secondary">@o.Email</div></td>
                                <td><code style="font-size:.78rem;">@o.OgrenciNo</code></td>
                                <td><span class="badge badge-secondary">@o.BolumKodu</span></td>
                                <td><span class="badge badge-success">Aktif</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <!-- Hızlı Erişim -->
    <div class="card">
        <div class="card-header">
            <div class="card-title"><i class="fas fa-bolt"></i> Hızlı Erişim</div>
        </div>
        <div class="card-body" style="display:flex; flex-direction:column; gap:8px;">
            <a href="/Admin/BolumOlustur" class="btn btn-outline-secondary w-100" style="justify-content:flex-start;">
                <i class="fas fa-plus" style="color:var(--color-role);"></i> Yeni Bölüm
            </a>
            <a href="/Admin/DonemOlustur" class="btn btn-outline-secondary w-100" style="justify-content:flex-start;">
                <i class="fas fa-calendar-plus" style="color:var(--color-role);"></i> Yeni Dönem
            </a>
            <a href="/Admin/DersOlustur" class="btn btn-outline-secondary w-100" style="justify-content:flex-start;">
                <i class="fas fa-book-medical" style="color:var(--color-role);"></i> Yeni Ders
            </a>
            <a href="/Admin/DersAtamaOlustur" class="btn btn-outline-secondary w-100" style="justify-content:flex-start;">
                <i class="fas fa-chalkboard-user" style="color:var(--color-role);"></i> Ders Ata
            </a>
            <div class="divider"></div>
            <a href="/Admin/AuditLogs" class="btn btn-outline-secondary w-100" style="justify-content:flex-start;">
                <i class="fas fa-clipboard-list" style="color:var(--color-gray-500);"></i> Denetim Kayıtları
            </a>
        </div>
    </div>
</div>
