@model StudentManagement.Services.ViewModels.Admin.AdminOgrenciOlusturViewModel
@{
    ViewData["Title"] = "Yeni Öğrenci Ekle";
    ViewData["Breadcrumb"] = "Yeni Öğrenci Ekle";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Yeni Öğrenci Ekle</h1>
        <p class="page-subtitle">Sisteme yeni öğrenci kaydı oluşturun.</p>
    </div>
    <div>
        <a href="@Url.Action("Ogrenciler", "Admin")" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Öğrenci Listesine Dön
        </a>
    </div>
</div>

<form asp-action="OgrenciOlustur" asp-controller="Admin" method="post">
    @Html.AntiForgeryToken()

    <div class="card" style="max-width:900px;">
        <div class="card-body" style="padding:28px 32px;">

            @* ── Kişisel Bilgiler ── *@
            <div style="margin-bottom:24px;">
                <h3 style="font-size:1rem; font-weight:700; color:var(--primary); margin-bottom:16px; display:flex; align-items:center; gap:8px;">
                    <i class="fas fa-user"></i> Kişisel Bilgiler
                </h3>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                    <div class="form-group">
                        <label asp-for="Ad" class="form-label">Ad <span class="required">*</span></label>
                        <input asp-for="Ad" class="form-control" placeholder="Öğrencinin adı" />
                        <span asp-validation-for="Ad" class="text-danger" style="font-size:.78rem;"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Soyad" class="form-label">Soyad <span class="required">*</span></label>
                        <input asp-for="Soyad" class="form-control" placeholder="Öğrencinin soyadı" />
                        <span asp-validation-for="Soyad" class="text-danger" style="font-size:.78rem;"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="TcKimlikNo" class="form-label">TC Kimlik No</label>
                        <input asp-for="TcKimlikNo" class="form-control" placeholder="11 haneli TC No" maxlength="11" />
                        <span asp-validation-for="TcKimlikNo" class="text-danger" style="font-size:.78rem;"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="DogumTarihi" class="form-label">Doğum Tarihi</label>
                        <input asp-for="DogumTarihi" type="date" class="form-control" />
                        <span asp-validation-for="DogumTarihi" class="text-danger" style="font-size:.78rem;"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Cinsiyet" class="form-label">Cinsiyet</label>
                        <select asp-for="Cinsiyet" class="form-control">
                            <option value="">Seçiniz...</option>
                            <option value="Erkek">Erkek</option>
                            <option value="Kadın">Kadın</option>
                        </select>
                        <span asp-validation-for="Cinsiyet" class="text-danger" style="font-size:.78rem;"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Telefon" class="form-label">Telefon</label>
                        <input asp-for="Telefon" class="form-control" placeholder="05XX XXX XX XX" />
                        <span asp-validation-for="Telefon" class="text-danger" style="font-size:.78rem;"></span>
                    </div>
                </div>
            </div>

            <hr style="border:none; border-top:1px solid var(--border, #e5e7eb); margin:24px 0;" />

            @* ── Hesap Bilgileri ── *@
            <div style="margin-bottom:24px;">
                <h3 style="font-size:1rem; font-weight:700; color:var(--primary); margin-bottom:16px; display:flex; align-items:center; gap:8px;">
                    <i class="fas fa-key"></i> Hesap Bilgileri
                </h3>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                    <div class="form-group">
                        <label asp-for="KullaniciAdi" class="form-label">Kullanıcı Adı <span class="required">*</span></label>
                        <input asp-for="KullaniciAdi" class="form-control" placeholder="Giriş yapılacak kullanıcı adı" />
                        <span asp-validation-for="KullaniciAdi" class="text-danger" style="font-size:.78rem;"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Email" class="form-label">E-posta <span class="required">*</span></label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="ornek@email.com" />
                        <span asp-validation-for="Email" class="text-danger" style="font-size:.78rem;"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Sifre" class="form-label">Şifre <span class="required">*</span></label>
                        <input asp-for="Sifre" class="form-control" type="password" placeholder="En az 6 karakter" />
                        <span asp-validation-for="Sifre" class="text-danger" style="font-size:.78rem;"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="SifreTekrar" class="form-label">Şifre Tekrar <span class="required">*</span></label>
                        <input asp-for="SifreTekrar" class="form-control" type="password" placeholder="Şifreyi tekrar giriniz" />
                        <span asp-validation-for="SifreTekrar" class="text-danger" style="font-size:.78rem;"></span>
                    </div>
                </div>
            </div>

            <hr style="border:none; border-top:1px solid var(--border, #e5e7eb); margin:24px 0;" />

            @* ── Akademik Bilgiler ── *@
            <div style="margin-bottom:24px;">
                <h3 style="font-size:1rem; font-weight:700; color:var(--primary); margin-bottom:16px; display:flex; align-items:center; gap:8px;">
                    <i class="fas fa-graduation-cap"></i> Akademik Bilgiler
                </h3>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                    <div class="form-group">
                        <label asp-for="BolumId" class="form-label">Bölüm <span class="required">*</span></label>
                        <select asp-for="BolumId" asp-items="Model.BolumListesi" class="form-control">
                            <option value="">Bölüm Seçiniz...</option>
                        </select>
                        <span asp-validation-for="BolumId" class="text-danger" style="font-size:.78rem;"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="SinifSeviyesi" class="form-label">Sınıf Seviyesi</label>
                        <select asp-for="SinifSeviyesi" class="form-control">
                            <option value="1">1. Sınıf</option>
                            <option value="2">2. Sınıf</option>
                            <option value="3">3. Sınıf</option>
                            <option value="4">4. Sınıf</option>
                        </select>
                        <span asp-validation-for="SinifSeviyesi" class="text-danger" style="font-size:.78rem;"></span>
                    </div>
                </div>
            </div>

            @* ── Bilgi Notu ── *@
            <div style="background:var(--bg-secondary, #f0f9ff); border-radius:10px; padding:14px 18px; margin-bottom:20px; border:1px solid #bee3f8;">
                <p style="margin:0; font-size:.82rem; color:var(--text-secondary, #555);">
                    <i class="fas fa-info-circle" style="color:var(--primary);"></i>
                    Öğrenci numarası kayıt sırasında otomatik olarak oluşturulacaktır. Şifre en az 6 karakter olmalıdır.
                </p>
            </div>

            @* ── Butonlar ── *@
            <div style="display:flex; justify-content:flex-end; gap:12px; padding-top:8px;">
                <a href="@Url.Action("Ogrenciler", "Admin")" class="btn btn-outline-secondary">
                    <i class="fas fa-times"></i> İptal
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-user-plus"></i> Öğrenci Oluştur
                </button>
            </div>

        </div>
    </div>
</form>
