@model StudentManagement.Services.ViewModels.Admin.DersDuzenleViewModel
@{
    ViewData["Title"]      = "Ders Düzenle";
    ViewData["Breadcrumb"] = "Ders Düzenle";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Ders Düzenle</h1>
        <p class="page-subtitle"><strong>@Model.DersKodu</strong> — @Model.DersAdi</p>
    </div>
    <a href="/Admin/DersKatalogu" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left"></i> Geri
    </a>
</div>

<div style="max-width:580px;">
    <div class="card">
        <div class="card-header">
            <div class="card-title"><i class="fas fa-pen"></i> Ders Bilgilerini Güncelle</div>
        </div>
        <div class="card-body">
            <form asp-action="DersDuzenle" asp-controller="Admin" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />

                <div class="form-group">
                    <label class="form-label">Ders Kodu</label>
                    <input class="form-control" value="@Model.DersKodu" disabled />
                    <div class="form-text">Ders kodu değiştirilemez.</div>
                </div>

                <div class="form-group">
                    <label asp-for="DersAdi" class="form-label">Ders Adı <span class="required">*</span></label>
                    <input asp-for="DersAdi" class="form-control" maxlength="150" />
                    <span asp-validation-for="DersAdi" class="invalid-feedback"></span>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Akts" class="form-label">AKTS <span class="required">*</span></label>
                        <input asp-for="Akts" class="form-control" type="number" min="1" max="8" />
                        <span asp-validation-for="Akts" class="invalid-feedback"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="MaxKontenjan" class="form-label">Kontenjan <span class="required">*</span></label>
                        <input asp-for="MaxKontenjan" class="form-control" type="number" min="1" max="500" />
                        <span asp-validation-for="MaxKontenjan" class="invalid-feedback"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Aciklama" class="form-label">Açıklama</label>
                    <textarea asp-for="Aciklama" class="form-control" rows="3" maxlength="500"></textarea>
                </div>

                <div class="form-group">
                    <label class="form-check">
                        <input asp-for="IsActive" type="checkbox" />
                        <span>Aktif</span>
                    </label>
                </div>

                <div style="display:flex; gap:10px; justify-content:flex-end;">
                    <a href="/Admin/DersKatalogu" class="btn btn-outline-secondary">İptal</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Güncelle
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
