@model IEnumerable<StudentManagement.Services.ViewModels.OgrenciIsleri.BelgeTalebiViewModel>
@{
    ViewData["Title"]      = "Belge Talepleri";
    ViewData["Breadcrumb"] = "Belge Talepleri";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Belge Talepleri</h1>
        <p class="page-subtitle">
            Bekleyen: <strong>@Model.Count(x => x.BelgeDurumAdi == "Beklemede")</strong>
            &nbsp;|&nbsp; Toplam: <strong>@Model.Count()</strong>
        </p>
    </div>
</div>

<div class="card table-card">
    <div class="table-toolbar">
        <div class="table-search">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="Öğrenci veya belge ara..." data-table="belgeTbl" />
        </div>
    </div>
    <div class="table-responsive">
        <table class="ubys-table" id="belgeTbl">
            <thead>
                <tr>
                    <th>Öğrenci</th>
                    <th>Belge Türü</th>
                    <th>Talep Tarihi</th>
                    <th>Durum</th>
                    <th>Yüklenen Belge</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model.OrderByDescending(x => x.CreatedAt))
                {
                    var (cls, lbl) = b.BelgeDurumAdi switch {
                        "Beklemede"    => ("badge-talep",      "Beklemede"),
                        "Hazirlaniyor" => ("badge-info",       "Hazırlanıyor"),
                        "Hazir"        => ("badge-success",    "Hazır"),
                        "Teslim"       => ("badge-tamamlandi", "Teslim Edildi"),
                        "Reddedildi"   => ("badge-reddedildi", "Reddedildi"),
                        _              => ("badge-secondary",  b.BelgeDurumAdi)
                    };
                    <tr>
                        <td>
                            <div class="primary">@b.OgrenciAdi</div>
                            <div class="secondary">@b.OgrenciNo</div>
                        </td>
                        <td><div class="primary">@b.BelgeTurAdi</div></td>
                        <td><span data-date="@b.CreatedAt" style="font-size:.8rem;"></span></td>
                        <td><span class="badge @cls">@lbl</span></td>

                        <td>
                            @if (!string.IsNullOrEmpty(b.BelgeDosyaYolu))
                            {
                                <a href="@Url.Action("BelgeIndir", "OgrenciIsleriPanel", new { yol = b.BelgeDosyaYolu, ad = b.BelgeDosyaAdi })"
                                   class="btn btn-sm btn-outline-primary" title="Belgeyi İndir" target="_blank">
                                    <i class="fas fa-file-download"></i>
                                    <span style="font-size:.75rem;">@(b.BelgeDosyaAdi?.Length > 20 ? b.BelgeDosyaAdi[..20] + "…" : b.BelgeDosyaAdi)</span>
                                </a>
                            }
                            else
                            {
                                <span class="text-muted" style="font-size:.8rem;">—</span>
                            }
                        </td>


                        <td>
                            <div style="display:flex; gap:6px; flex-wrap:wrap; align-items:center;">
                                @if (b.BelgeDurumAdi != "Teslim" && b.BelgeDurumAdi != "Reddedildi")
                                {
                                    <form asp-action="BelgeDurumGuncelle" asp-controller="OgrenciIsleriPanel"
                                          method="post" style="display:inline-flex; gap:4px;"
                                          enctype="multipart/form-data">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="BelgeTalebiId" value="@b.Id" />
                                        <select name="YeniBelgeDurum" class="form-control"
                                                style="width:140px; font-size:.75rem; padding:5px 8px;">
                                            <option value="Hazirlaniyor">Hazırlanıyor</option>
                                            <option value="Hazir">Hazır</option>
                                            <option value="Teslim">Teslim Edildi</option>
                                            <option value="Reddedildi">Reddedildi</option>
                                        </select>
                                        <button type="submit" class="btn btn-primary btn-sm" title="Durumu Kaydet">
                                            <i class="fas fa-save"></i>
                                        </button>
                                    </form>

                                    <button type="button" class="btn btn-success btn-sm"
                                            title="Belge Yükle"
                                            onclick="belgeYukleModalAc(@b.Id, '@b.OgrenciAdi', '@b.BelgeTurAdi')">
                                        <i class="fas fa-upload"></i> Belge Yükle
                                    </button>
                                }
                                else
                                {
                                    <span class="text-muted" style="font-size:.8rem;">İşlem tamamlandı</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


<div id="belgeYukleModal" class="modal-overlay" style="display:none;" onclick="modalDis(event)">
    <div class="modal-box" style="max-width:500px;">
        <div class="modal-header">
            <h3 class="modal-title">
                <i class="fas fa-upload" style="color:var(--success);"></i>
                Belge Yükle
            </h3>
            <button type="button" class="modal-close" onclick="belgeYukleModalKapat()">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <form asp-action="BelgeYukle" asp-controller="OgrenciIsleriPanel"
              method="post" enctype="multipart/form-data" id="belgeYukleForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="belgeTalebiId" id="modalBelgeTalebiId" value="" />

            <div class="modal-body">
                <div class="belge-yukle-info" id="modalBilgi" style="
                    background: var(--bg-secondary, #f8f9fa);
                    border-radius: 8px;
                    padding: 12px 16px;
                    margin-bottom: 16px;
                    font-size: .88rem;
                    color: var(--text-secondary, #666);
                ">
                    <i class="fas fa-user-graduate"></i>
                    <span id="modalOgrenciAdi">—</span> &nbsp;|&nbsp;
                    <i class="fas fa-file-alt"></i>
                    <span id="modalBelgeTuru">—</span>
                </div>

                <div class="form-group">
                    <label class="form-label" for="belgeFile">
                        <i class="fas fa-paperclip"></i> Yüklenecek Dosya
                        <span style="color:var(--danger,#e74c3c);">*</span>
                    </label>
                    <div class="file-upload-area" id="fileUploadArea"
                         onclick="document.getElementById('belgeFile').click()"
                         ondragover="event.preventDefault()" ondrop="handleDrop(event)">
                        <i class="fas fa-cloud-upload-alt" style="font-size:2rem; color:var(--primary,#3b5bdb); margin-bottom:8px;"></i>
                        <p style="margin:0; font-weight:600;">Dosyayı sürükleyin veya tıklayın</p>
                        <p style="margin:0; font-size:.8rem; color:#888; margin-top:4px;" id="dosyaAdiLabel">
                            PDF, Word, JPG, PNG — Maks. 10 MB
                        </p>
                    </div>
                    <input type="file" name="belgeFile" id="belgeFile" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png"
                           style="display:none;" onchange="dosyaSecildi(this)" required />
                </div>

                <div id="filePreview" style="display:none; margin-top:12px; padding:10px 14px;
                     background:#f0f9ff; border-radius:8px; border:1px solid #bee3f8;">
                    <i class="fas fa-file-check" style="color:#3b5bdb;"></i>
                    <span id="filePreviewName" style="font-size:.85rem; font-weight:500;"></span>
                    <span id="filePreviewSize" style="font-size:.78rem; color:#666; margin-left:6px;"></span>
                    <button type="button" onclick="dosyaTemizle()" style="
                        float:right; background:none; border:none; color:#e53e3e; cursor:pointer;
                    "><i class="fas fa-times-circle"></i></button>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="belgeYukleModalKapat()">
                    İptal
                </button>
                <button type="submit" class="btn btn-success" id="yukleBtn">
                    <i class="fas fa-upload"></i> Yükle
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .file-upload-area {
        border: 2px dashed var(--primary, #3b5bdb);
        border-radius: 10px;
        padding: 28px 20px;
        text-align: center;
        cursor: pointer;
        transition: background .2s, border-color .2s;
        user-select: none;
    }
    .file-upload-area:hover,
    .file-upload-area.drag-over {
        background: rgba(59,91,219,.06);
        border-color: var(--primary-dark, #2f4ccd);
    }
    .modal-overlay {
        position: fixed; inset: 0;
        background: rgba(0,0,0,.55);
        z-index: 1050;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(3px);
    }
    .modal-box {
        background: var(--bg-card, #fff);
        border-radius: 14px;
        width: 90%;
        max-width: 500px;
        box-shadow: 0 20px 60px rgba(0,0,0,.25);
        overflow: hidden;
        animation: modalIn .22s ease;
    }
    @@keyframes modalIn {
        from { opacity:0; transform: scale(.92) translateY(20px); }
        to   { opacity:1; transform: scale(1) translateY(0); }
    }
    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 24px 14px;
        border-bottom: 1px solid var(--border, #e5e7eb);
    }
    .modal-title { margin: 0; font-size: 1.1rem; font-weight: 700; display: flex; align-items: center; gap: 8px; }
    .modal-close  { background: none; border: none; font-size: 1.2rem; cursor: pointer; color: #888; padding: 4px 8px; border-radius: 6px; }
    .modal-close:hover { background: var(--bg-secondary, #f3f4f6); color: var(--danger, #e74c3c); }
    .modal-body   { padding: 20px 24px; }
    .modal-footer { display: flex; justify-content: flex-end; gap: 10px; padding: 14px 24px 20px; border-top: 1px solid var(--border, #e5e7eb); }
    .btn-outline-primary { border: 1.5px solid var(--primary,#3b5bdb); color: var(--primary,#3b5bdb); background: transparent; }
    .btn-outline-primary:hover { background: var(--primary,#3b5bdb); color: #fff; }
</style>

<script>
    // Modal aç/kapat
    function belgeYukleModalAc(id, ogrenciAdi, belgeTuru) {
        document.getElementById('modalBelgeTalebiId').value = id;
        document.getElementById('modalOgrenciAdi').textContent  = ogrenciAdi;
        document.getElementById('modalBelgeTuru').textContent   = belgeTuru;
        dosyaTemizle();
        document.getElementById('belgeYukleModal').style.display = 'flex';
    }
    function belgeYukleModalKapat() {
        document.getElementById('belgeYukleModal').style.display = 'none';
    }
    function modalDis(e) {
        if (e.target === document.getElementById('belgeYukleModal'))
            belgeYukleModalKapat();
    }

    // Dosya seçimi
    function dosyaSecildi(input) {
        if (!input.files || !input.files[0]) return;
        const f = input.files[0];
        const maxMB = 10;
        if (f.size > maxMB * 1024 * 1024) {
            alert('Dosya ' + maxMB + ' MB\'ı aşamaz!');
            input.value = '';
            return;
        }
        document.getElementById('filePreviewName').textContent = f.name;
        document.getElementById('filePreviewSize').textContent = '(' + (f.size / 1024).toFixed(1) + ' KB)';
        document.getElementById('filePreview').style.display = 'block';
        document.getElementById('dosyaAdiLabel').textContent = f.name;
    }

    function dosyaTemizle() {
        const inp = document.getElementById('belgeFile');
        if (inp) inp.value = '';
        document.getElementById('filePreview').style.display = 'none';
        document.getElementById('dosyaAdiLabel').textContent = 'PDF, Word, JPG, PNG — Maks. 10 MB';
    }

    // Drag & drop
    function handleDrop(e) {
        e.preventDefault();
        const dt = e.dataTransfer;
        if (dt.files && dt.files[0]) {
            const inp = document.getElementById('belgeFile');
            // DataTransfer ile input'a yükle
            const dT = new DataTransfer();
            dT.items.add(dt.files[0]);
            inp.files = dT.files;
            dosyaSecildi(inp);
        }
        document.getElementById('fileUploadArea').classList.remove('drag-over');
    }
    document.addEventListener('DOMContentLoaded', function () {
        const area = document.getElementById('fileUploadArea');
        if (!area) return;
        area.addEventListener('dragover',  function(e){ e.preventDefault(); area.classList.add('drag-over'); });
        area.addEventListener('dragleave', function()  { area.classList.remove('drag-over'); });
    });
</script>
