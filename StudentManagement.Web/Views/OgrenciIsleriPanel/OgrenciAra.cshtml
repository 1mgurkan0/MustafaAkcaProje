@model StudentManagement.Services.ViewModels.OgrenciIsleri.OgrenciAraViewModel
@{
    ViewData["Title"]      = "Öğrenci Ara";
    ViewData["Breadcrumb"] = "Öğrenci Ara";
}

<div class="page-header">
    <div><h1 class="page-title">Öğrenci Ara</h1></div>
</div>

<!-- Arama Formu -->
<div class="card" style="margin-bottom:20px;">
    <div class="card-body">
        <form asp-action="OgrenciAra" asp-controller="OgrenciIsleriPanel"
              method="get" id="araForm">
            <div style="display:flex; gap:12px; align-items:flex-end; flex-wrap:wrap;">
                <div class="form-group" style="flex:1; min-width:200px; margin-bottom:0;">
                    <label class="form-label">Ad Soyad / Öğrenci No / E-posta</label>
                    <div class="input-icon">
                        <i class="fas fa-search"></i>
                        <input name="arama" class="form-control" value="@Model.Arama"
                               placeholder="Arama yapın..." autofocus />
                    </div>
                </div>
                <div class="form-group" style="min-width:160px; margin-bottom:0;">
                    <label class="form-label">Bölüm</label>
                    <select name="bolumId" class="form-control"
                            asp-items="ViewBag.Bolumler">
                        <option value="">Tüm Bölümler</option>
                    </select>
                </div>
                <div class="form-group" style="margin-bottom:0;">
                    <label class="form-label" style="visibility:hidden;">Ara</label>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-search"></i> Ara
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Sonuçlar -->
@if (Model.Sonuclar != null)
{
    <div class="card table-card">
        <div class="card-header">
            <div class="card-title">
                <i class="fas fa-users"></i>
                Arama Sonuçları
                <span class="badge badge-secondary" style="margin-left:6px;">
                    @Model.Sonuclar.Count kayıt
                </span>
            </div>
        </div>
        <div class="table-responsive">
            <table class="ubys-table">
                <thead>
                    <tr>
                        <th>Öğrenci No</th>
                        <th>Ad Soyad</th>
                        <th>E-posta</th>
                        <th>Bölüm</th>
                        <th>GANO</th>
                        <th>Durum</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model.Sonuclar)
                    {
                        <tr>
                            <td><code style="font-size:.76rem;">@o.OgrenciNo</code></td>
                            <td><div class="primary">@o.AdSoyad</div></td>
                            <td><span class="text-sm text-muted">@o.Email</span></td>
                            <td><span class="badge badge-secondary">@o.BolumAdi</span></td>
                            <td>
                                @{
                                    var ganoRenk = (o.Gano.HasValue && (double)o.Gano.Value >= 2.0)
                                        ? "var(--color-success)" : "var(--color-danger)";
                                }
                                <strong style="color:@ganoRenk;">
                                    @(o.Gano.HasValue ? o.Gano.Value.ToString("F2") : "—")
                                </strong>
                            </td>
                            <td>
                                @{
                                    var durumStr = o.Durum.ToString();
                                    string cls2, lbl2;
                                    switch (durumStr) {
                                        case "Aktif":        cls2 = "badge-success";   lbl2 = "Aktif"; break;
                                        case "Mezun":        cls2 = "badge-info";      lbl2 = "Mezun"; break;
                                        case "Dondurulmus":  cls2 = "badge-warning";   lbl2 = "Dondurulmuş"; break;
                                        default:             cls2 = "badge-secondary"; lbl2 = durumStr; break;
                                    }
                                }
                                <span class="badge @cls2">@lbl2</span>
                            </td>
                            <td>
                                <div style="display:flex; gap:6px;">
                                    <a href="@Url.Action("OgrenciGuncelle", "OgrenciIsleriPanel", new { id = o.OgrenciId })"
                                       class="btn btn-outline-primary btn-xs" title="Düzenle">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button class="btn btn-outline-danger btn-xs"
                                            onclick="openSilModal(@o.OgrenciId, '@o.AdSoyad')" title="Sil">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                    <a href="/OgrenciIsleri/OgrenciDetay/@o.OgrenciId"
                                       class="btn btn-outline-secondary btn-xs">
                                        Detay
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Sonuclar.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon"><i class="fas fa-magnifying-glass"></i></div>
                <div class="empty-state-title">Sonuç bulunamadı</div>
                <div class="empty-state-text">Arama kriterlerinizi değiştirerek tekrar deneyin.</div>
            </div>
        }
    </div>
}

<div class="modal-overlay" id="silModal">
    <div class="modal-box" style="max-width: 400px;">
        <div class="modal-header">
            <span class="modal-title" style="color:var(--color-danger);"><i class="fas fa-exclamation-triangle"></i> Öğrenciyi Sil</span>
            <button class="modal-close"><i class="fas fa-times"></i></button>
        </div>
        <div class="modal-body text-center">
            <div style="font-size:3rem; color:var(--color-danger); margin-bottom:16px;">
                <i class="fas fa-trash-alt"></i>
            </div>
            <p style="margin-bottom:16px;">
                <strong><span id="silOgrenciAdi"></span></strong> isimli öğrenciyi kalıcı olarak silmek istediğinize emin misiniz?
            </p>
            <p style="font-size:.85rem; color:var(--color-gray-500); margin-bottom:24px;">
                Eğer öğrencinin ilişkili kayıtları (ders notları vs.) varsa silme işlemi gerçekleşmeyecektir. Bu durumda öğrencinin durumunu "İlişiği Kesildi" yapmanız önerilir.
            </p>
            
            <form asp-action="OgrenciSil" asp-controller="OgrenciIsleriPanel" method="post" id="silForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="silOgrenciId" />
                <div style="display:flex; justify-content:center; gap:12px;">
                    <button type="button" class="btn btn-outline-secondary modal-close">İptal</button>
                    <button type="submit" class="btn btn-danger">Evet, Sil</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openSilModal(id, ad) {
            document.getElementById("silOgrenciId").value = id;
            document.getElementById("silOgrenciAdi").textContent = ad;
            SMS.modal.show("silModal");
        }
    </script>
}
