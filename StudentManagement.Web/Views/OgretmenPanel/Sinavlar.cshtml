@model StudentManagement.Services.ViewModels.Ogretmen.SinavlarViewModel
@{
    ViewData["Title"]      = "Sınavlar";
    ViewData["Breadcrumb"] = "Sınavlar";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Sınavlarım</h1>
        <p class="page-subtitle">Tüm derslerinize ait sınav programı.</p>
    </div>
    <button class="btn btn-primary" onclick="SMS.modal.show('sinavEkleModal')">
        <i class="fas fa-plus"></i> Sınav Ekle
    </button>
</div>

<div class="card table-card">
    <div class="table-toolbar">
        <div class="table-search">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="Ders veya sınav ara..." data-table="sinavTbl" />
        </div>
    </div>
    <div class="table-responsive">
        <table class="ubys-table" id="sinavTbl">
            <thead>
                <tr>
                    <th>Ders</th>
                    <th>Sınav Türü</th>
                    <th>Tarih / Saat</th>
                    <th>Yer</th>
                    <th>Açıklama</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.Sinavlar.OrderBy(x => x.SinavTarihi))
                {
                    <tr>
                        <td>
                            <div class="primary">@s.DersAdi</div>
                            <div class="secondary">@s.DersKodu</div>
                        </td>
                        <td>
                            @{
                                var turClass = s.SinavTurAdi switch {
                                    "Vize"         => "badge-warning",
                                    "Final"        => "badge-danger",
                                    "Butunleme"    => "badge-info",
                                    _              => "badge-secondary"
                                };
                            }
                            <span class="badge @turClass">@s.SinavTurAdi</span>
                        </td>
                        <td>
                            <div style="font-weight:700; font-size:.83rem;"
                                 data-datetime="@s.SinavTarihi"></div>
                        </td>
                        <td>@(string.IsNullOrEmpty(s.Derslik) ? "—" : s.Derslik)</td>
                        <td>
                            <span style="font-size:.78rem; color:var(--color-gray-500);">
                                @(string.IsNullOrEmpty(s.Aciklama) ? "—" : s.Aciklama)
                            </span>
                        </td>
                        <td>
                            <form asp-action="SinavSil" asp-controller="OgretmenPanel"
                                  asp-route-id="@s.Id" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-outline-danger btn-icon btn-sm"
                                        data-confirm="Bu sınavı silmek istediğinize emin misiniz?"
                                        data-confirm-type="danger"
                                        data-confirm-btn="Evet, Sil">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (!Model.Sinavlar.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon"><i class="fas fa-file-pen"></i></div>
            <div class="empty-state-title">Henüz sınav eklenmemiş</div>
        </div>
    }
</div>

<!-- Sınav Ekle Modal -->
<div class="modal-overlay" id="sinavEkleModal">
    <div class="modal-box">
        <div class="modal-header">
            <span class="modal-title">Yeni Sınav Ekle</span>
            <button class="modal-close"><i class="fas fa-times"></i></button>
        </div>
        <div class="modal-body">
            <form asp-action="SinavEkle" asp-controller="OgretmenPanel"
                  method="post" id="sinavForm" novalidate>
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="form-label">Ders <span class="required">*</span></label>
                    <select name="DersAtamaId" class="form-control"
                            asp-items="ViewBag.DersAtamalar">
                        <option value="">— Ders seçiniz —</option>
                    </select>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Sınav Türü <span class="required">*</span></label>
                        <select name="SinavTur" class="form-control"
                                asp-items="Html.GetEnumSelectList<StudentManagement.Core.Enums.SinavTur>()">
                            <option value="">— Seçiniz —</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Tarih <span class="required">*</span></label>
                        <input name="Tarih" class="form-control" type="datetime-local" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Yer</label>
                    <input name="Yer" class="form-control" placeholder="örn: A-201, Online" maxlength="50" />
                </div>
                <div class="form-group">
                    <label class="form-label">Açıklama</label>
                    <textarea name="Aciklama" class="form-control" rows="2" maxlength="500"></textarea>
                </div>

                <div class="modal-footer" style="padding:0; border:none; margin-top:8px;">
                    <button type="button" class="btn btn-outline-secondary modal-close">İptal</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
