@model IEnumerable<StudentManagement.Services.ViewModels.Ogretmen.DersAtamaOzetViewModel>
@{
    ViewData["Title"]      = "Derslerim";
    ViewData["Breadcrumb"] = "Derslerim";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Derslerim</h1>
        <p class="page-subtitle">Bu dönem üstlendiğiniz dersler.</p>
    </div>
</div>

@if (Model.Any())
{
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(320px,1fr)); gap:20px;">
        @foreach (var d in Model)
        {
            var oran      = d.MaxKontenjan > 0 ? (int)((double)d.KayitliOgrenciSayisi / d.MaxKontenjan * 100) : 0;
            var oranClass = oran >= 90 ? "danger" : oran >= 60 ? "warning" : "success";
            <div class="card" style="transition:var(--transition);"
                 onmouseover="this.style.boxShadow='var(--shadow-lg)'"
                 onmouseout="this.style.boxShadow=''">
                <div class="card-header">
                    <div>
                        <div style="font-weight:800; font-size:.95rem; color:var(--color-gray-900);">@d.DersAdi</div>
                        <div style="font-size:.75rem; color:var(--color-gray-400); margin-top:2px;">
                            <span class="badge badge-secondary">@d.DersKodu</span>
                            <span style="margin-left:6px;">@d.Akts AKTS</span>
                        </div>
                    </div>
                    <span class="badge badge-role">@d.DonemAdi</span>
                </div>
                <div class="card-body">
                    <!-- Ders Bilgileri -->
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:14px;">
                        <div style="font-size:.78rem;">
                            <div style="color:var(--color-gray-400); font-weight:600; margin-bottom:2px;">GÜN / SAAT</div>
                            <div style="font-weight:700; color:var(--color-gray-800);">@d.Gun — @d.Saat</div>
                        </div>
                        <div style="font-size:.78rem;">
                            <div style="color:var(--color-gray-400); font-weight:600; margin-bottom:2px;">DERSLİK</div>
                            <div style="font-weight:700; color:var(--color-gray-800);">@d.Derslik</div>
                        </div>
                    </div>

                    <!-- Doluluk -->
                    <div style="margin-bottom:14px;">
                        <div class="d-flex items-center justify-between mb-1">
                            <span style="font-size:.75rem; font-weight:700; color:var(--color-gray-600);">Kayıtlı Öğrenci</span>
                            <span style="font-size:.75rem; font-weight:700;">@d.KayitliOgrenciSayisi / @d.MaxKontenjan</span>
                        </div>
                        <div class="progress">
                            <div class="progress-bar @oranClass" style="width:@oran%"></div>
                        </div>
                    </div>

                    <!-- Aksiyonlar -->
                    <div style="display:flex; gap:8px; flex-wrap:wrap;">
                        <a href="/OgretmenPanel/DersDetay/@d.DersAtamaId"
                           class="btn btn-primary btn-sm" style="flex:1;">
                            <i class="fas fa-eye"></i> Detay
                        </a>
                        <a href="/OgretmenPanel/NotGir?dersAtamaId=@d.DersAtamaId"
                           class="btn btn-outline-secondary btn-sm" style="flex:1;">
                            <i class="fas fa-pen-to-square"></i> Not Gir
                        </a>
                        <a href="/OgretmenPanel/Yoklama?dersAtamaId=@d.DersAtamaId"
                           class="btn btn-outline-secondary btn-sm" style="flex:1;">
                            <i class="fas fa-clipboard-check"></i> Yoklama
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="card">
        <div class="empty-state">
            <div class="empty-state-icon"><i class="fas fa-chalkboard"></i></div>
            <div class="empty-state-title">Bu dönem atanmış ders bulunmuyor</div>
            <div class="empty-state-text">Ders ataması için yönetici ile iletişime geçin.</div>
        </div>
    </div>
}
