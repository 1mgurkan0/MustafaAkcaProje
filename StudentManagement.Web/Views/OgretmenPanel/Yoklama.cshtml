@model StudentManagement.Services.ViewModels.Ogretmen.YoklamaGirViewModel
@{
    ViewData["Title"]      = "Yoklama";
    ViewData["Breadcrumb"] = "Yoklama Al";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Yoklama Al</h1>
        <p class="page-subtitle"><strong>@Model.DersAdi</strong> · @Model.DonemAdi</p>
    </div>
    <a href="/OgretmenPanel/DersDetay/@Model.DersAtamaId" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left"></i> Geri
    </a>
</div>

<div class="card" style="max-width:800px;">
    <div class="card-header">
        <div class="card-title"><i class="fas fa-clipboard-check"></i> Yoklama Formu</div>
    </div>
    <div class="card-body">
        <form asp-action="Yoklama" asp-controller="OgretmenPanel" method="post" id="yoklamaForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="DersAtamaId" />

            <div class="form-row" style="margin-bottom:20px;">
                <div class="form-group">
                    <label asp-for="YoklamaTarihi" class="form-label">
                        Yoklama Tarihi <span class="required">*</span>
                    </label>
                    <input asp-for="YoklamaTarihi" class="form-control" type="date"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="YoklamaTarihi" class="invalid-feedback"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">Hızlı Seçim</label>
                    <div style="display:flex; gap:8px;">
                        <button type="button" class="btn btn-success btn-sm"
                                onclick="setAll(true)">
                            <i class="fas fa-check"></i> Tümü Var
                        </button>
                        <button type="button" class="btn btn-danger btn-sm"
                                onclick="setAll(false)">
                            <i class="fas fa-times"></i> Tümü Yok
                        </button>
                    </div>
                </div>
            </div>

            <!-- Öğrenci Listesi -->
            <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:10px; margin-bottom:20px;">
                @for (int i = 0; i < Model.OgrenciListesi.Count; i++)
                {
                    var o = Model.OgrenciListesi[i];
                    <input type="hidden" name="OgrenciListesi[@i].OgrenciId" value="@o.OgrenciId" />
                    <div class="yoklama-ogrenci-card" id="card-@i"
                         style="display:flex; align-items:center; justify-content:space-between;
                                padding:10px 14px; border:1.5px solid var(--color-gray-200);
                                border-radius:8px; cursor:pointer; transition:var(--transition);"
                         onclick="toggleYoklama(@i)">
                        <div>
                            <div style="font-weight:700; font-size:.83rem;">@o.OgrenciAdi</div>
                            <div style="font-size:.72rem; color:var(--color-gray-400);">@o.OgrenciNo</div>
                        </div>
                        <div style="display:flex; align-items:center; gap:8px;">
                            <span id="status-@i" class="badge"
                                  style="min-width:40px; text-align:center;">
                                VAR
                            </span>
                            <input type="hidden" name="OgrenciListesi[@i].Geldi"
                                   id="hidden-@i" value="true" />
                        </div>
                    </div>
                }
            </div>

            <div style="display:flex; justify-content:space-between; align-items:center;">
                <div style="font-size:.8rem; color:var(--color-gray-500);">
                    Toplam: <strong>@Model.OgrenciListesi.Count</strong> öğrenci
                </div>
                <div style="display:flex; gap:10px;">
                    <a href="/OgretmenPanel/DersDetay/@Model.DersAtamaId"
                       class="btn btn-outline-secondary">İptal</a>
                    <button type="submit" class="btn btn-primary" id="saveBtn">
                        <i class="fas fa-save"></i> Yoklamayı Kaydet
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const states = {};

        // Başlangıçta herkesi "var" yap
        document.querySelectorAll("[id^='card-']").forEach((card, i) => {
            states[i] = true;
            updateCard(i);
        });

        function toggleYoklama(i) {
            states[i] = !states[i];
            updateCard(i);
        }

        function updateCard(i) {
            const card   = document.getElementById(`card-${i}`);
            const status = document.getElementById(`status-${i}`);
            const hidden = document.getElementById(`hidden-${i}`);

            if (states[i]) {
                card.style.borderColor    = "var(--color-success)";
                card.style.background     = "var(--color-success-bg)";
                status.className          = "badge badge-success";
                status.textContent        = "VAR";
                hidden.value             = "true";
            } else {
                card.style.borderColor    = "var(--color-danger)";
                card.style.background     = "var(--color-danger-bg)";
                status.className          = "badge badge-danger";
                status.textContent        = "YOK";
                hidden.value             = "false";
            }
        }

        function setAll(val) {
            Object.keys(states).forEach(i => {
                states[i] = val;
                updateCard(parseInt(i));
            });
        }

        document.getElementById("yoklamaForm").addEventListener("submit", function () {
            SMS.form.setLoading(this, true);
        });
    </script>
}
